{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the LinkPilot main window",
  "windows": ["main", "picker"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:window:allow-toggle-maximize",
    "core:event:default",
    "deep-link:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$HOME/Library/Application Support/LinkPilot/updates/*.dmg" }
      ]
    }
  ]
}
