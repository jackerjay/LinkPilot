{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LinkPilot",
  "version": "0.1.0",
  "identifier": "app.linkpilot.desktop",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "LinkPilot",
        "width": 900,
        "height": 640,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
