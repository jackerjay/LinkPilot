# Pin this package's npm/bun operations to the public registry,
# regardless of any internal mirror the maintainer's global ~/.npmrc
# points at (e.g. bnpm.byted.org). Without this, `bun install` here
# generates a `bun.lock` whose tarball URLs reference the internal
# host — and CI on GitHub Actions can't reach those, so install
# fails with "FailedToOpenSocket" / "ConnectionRefused".
#
# Applies to:
# - `bun install` (bun reads .npmrc for the `registry` key)
# - `npm install` and `npm publish` (same)
# - `npm login` for this package (use --scope=@linkpilot to attach)
registry=https://registry.npmjs.org/
@linkpilot:registry=https://registry.npmjs.org/
